use crate::context::Context;
use anyhow::{anyhow, Result};
use clap::{ArgMatches, Parser};
use {{ progenitor_crate_name }}::{CliCommand, Cli as ApiCli};

#[derive(Parser, Debug)]
#[command(name = "{{ bin_name }}", about = "Generated API CLI")]
pub struct Cli {}

impl Cli {
    pub fn command() -> clap::Command {
        let mut command = <Self as Parser>::command();
        for api_command in CliCommand::iter() {
            command = command.subcommand(ApiCli::<Context>::get_command(api_command));
        }
        command
    }
}

pub async fn dispatch(context: &Context, matches: &ArgMatches) -> Result<()> {
    let Some((name, submatches)) = matches.subcommand() else {
        let mut command = Cli::command();
        command.print_help()?;
        println!();
        return Ok(());
    };

    for api_command in CliCommand::iter() {
        let command = ApiCli::<Context>::get_command(api_command);
        if command.get_name() == name {
            let client = {{ progenitor_crate_name }}::Client::new_with_client(
                &context.base_url,
                context.client.clone(),
            );
            let cli = ApiCli::new(client, context.clone_for_cli());
            return cli.execute(api_command, submatches).await;
        }
    }

    Err(anyhow!("unknown generated command: {name}"))
}

impl Context {
    fn clone_for_cli(&self) -> Self {
        Self {
            client: self.client.clone(),
            base_url: self.base_url.clone(),
            auth: self.auth.clone(),
        }
    }
}
