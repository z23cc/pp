use crate::context::Context;
use anyhow::{anyhow, Result};
use clap::{ArgMatches, Parser};

#[derive(Parser, Debug)]
#[command(name = "{{ bin_name }}", about = "Generated API CLI")]
pub struct Cli {}

impl Cli {
    pub fn command() -> clap::Command {
        let mut command = <Self as clap::CommandFactory>::command();
{% for operation in operations %}
        command = command.subcommand(clap::Command::new("{{ operation.command_name }}"));
{% endfor %}
        command
    }
}

pub async fn dispatch(context: &Context, matches: &ArgMatches) -> Result<()> {
    let Some((name, _submatches)) = matches.subcommand() else {
        let mut command = Cli::command();
        command.print_help()?;
        println!();
        return Ok(());
    };

    let client = {{ progenitor_crate_name }}::Client::new_with_client(
        &context.base_url,
        context.client.clone(),
    );

    match name {
{% for operation in operations %}
        "{{ operation.command_name }}" => {
            let value = client.{{ operation.method_name }}().await;
            crate::print::print_result(value)
        }
{% endfor %}
        _ => Err(anyhow!("unknown generated command: {name}")),
    }
}
