[workspace]
members = ["api", "."]
resolver = "2"

[package]
name = "{{ bin_name }}"
version = "0.1.0"
edition = "2021"

[dependencies]
anyhow = "1"
clap = { version = "4", features = ["derive"] }
{{ progenitor_lib_name }} = { path = "api" }
progenitor-client = "0.14"
reqwest = { version = "0.13", features = ["json"] }
schemars = "0.8"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tokio = { version = "1", features = ["macros", "rt-multi-thread"] }
