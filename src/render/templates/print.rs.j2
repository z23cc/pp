use anyhow::{anyhow, Result};
use progenitor_client::{Error, ResponseValue};

pub fn print_result<T>(value: Result<ResponseValue<T>, Error<()>>) -> Result<()>
where
    T: std::fmt::Debug,
{
    match value {
        Ok(value) => {
            println!("{:#?}", value.into_inner());
            Ok(())
        }
        Err(error) => Err(anyhow!("API request failed: {error:?}")),
    }
}
